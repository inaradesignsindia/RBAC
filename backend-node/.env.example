# Microsoft Entra ID / Graph API
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-app-client-id
GRAPH_CLIENT_SECRET=your-app-client-secret
TENANT_DOMAIN=yourdomain.onmicrosoft.com

# Server
PORT=3000

# Database (Oracle Autonomous AI DB or PostgreSQL)
DATABASE_URL=oracle://user:pass@hostname:1522/service
# or
DATABASE_URL=postgresql://user:pass@localhost:5432/rbac
